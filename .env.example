# Forage Graph API — Environment Variables
# Copy to .env for local dev. Set in Railway dashboard for production.

# FalkorDB / Redis connection
# Railway: add a FalkorDB or Redis service, copy the connection URL here
FALKORDB_URL=redis://localhost:6379

# Auth secret — generate with: openssl rand -hex 32
# Must match GRAPH_API_SECRET in the Apify actor env vars
GRAPH_API_SECRET=6da69224eb14e6bdb0fb63514b772480d23a4467f8ac8a4b15266a8262d7f959

# Port (Railway sets this automatically)
PORT=3000
